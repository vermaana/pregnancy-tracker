root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = android_studio

# Trailing commas — required for Compose multi-param functions to format cleanly
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ktlint_standard_trailing-comma-on-declaration-site = always
ktlint_standard_trailing-comma-on-call-site = always

# Allow @Composable functions to use PascalCase (e.g. fun MyScreen())
ktlint_function_naming_ignore_when_annotated_with = Composable

# Wildcard imports are disallowed
ktlint_standard_no-wildcard-imports = enabled

[*.xml]
indent_size = 4
